# EcoClear AI Agent Service Configuration
# Copy to .env and fill in values

# Google Gemini API Key (same as used by Genkit in the Next.js app)
GOOGLE_API_KEY=

# LangSmith observability (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ecoclear-ai-agent

# Service configuration
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info

# GIS service URL (for cross-service calls)
GIS_SERVICE_URL=http://localhost:8002
