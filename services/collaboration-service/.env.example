# Hocuspocus Collaboration Service Configuration
# Copy to .env and fill in values

# Service configuration
HOST=0.0.0.0
PORT=8003

# Authentication secret (shared with Next.js frontend)
AUTH_SECRET=ecoclear-collab-dev-secret

# SQLite database path for document persistence
SQLITE_DB_PATH=./data/documents.db

# Allowed origins for WebSocket connections
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9002

# Throttle settings (requests per minute per connection)
THROTTLE_LIMIT=15
THROTTLE_INTERVAL=1000
