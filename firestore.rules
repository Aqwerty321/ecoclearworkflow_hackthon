rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: fetch calling user's profile doc
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserDoc().data.role == 'Admin';
    }

    function isScrutiny() {
      return isAuthenticated() && (
        getUserDoc().data.role == 'Scrutiny Team' || isAdmin()
      );
    }

    function isMoM() {
      return isAuthenticated() && (
        getUserDoc().data.role == 'MoM Team' || isAdmin()
      );
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── users ─────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── applications ──────────────────────────────────────
    match /applications/{appId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.applicantId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.applicantId == request.auth.uid
        || isScrutiny()
        || isMoM()
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── documents ─────────────────────────────────────────
    match /documents/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isScrutiny();
      allow delete: if isAdmin();
    }

    // ── sectors ───────────────────────────────────────────
    match /sectors/{sectorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── edsComments ───────────────────────────────────────
    match /edsComments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isScrutiny();
      allow update, delete: if isAdmin();
    }

    // ── meetingGists ──────────────────────────────────────
    match /meetingGists/{gistId} {
      allow read: if isAuthenticated();
      allow write: if isMoM() || isScrutiny();
    }

    // ── templates ─────────────────────────────────────────
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── payments ──────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── minutesOfMeeting ──────────────────────────────────
    match /minutesOfMeeting/{momId} {
      allow read: if isAuthenticated();
      allow write: if isMoM() || isAdmin();
    }
  }
}
